{
  "name": "java-springboot-testcontainers",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "init": true,
  "shutdownAction": "stopContainer",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1.9.1": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "none",
      "installDockerComposeSwitch": false
    }
  },
  "remoteUser": "vscode",
  "runArgs": [
    "--add-host=host.docker.internal:host-gateway",
    "--env-file", "${localWorkspaceFolder}/.env"
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=${localWorkspaceFolder},type=bind",
  "workspaceFolder": "${localWorkspaceFolder}",
  "containerEnv": {
    "COMPOSE_DOCKER_CLI_BUILD": "1",
    "DOCKER_BUILDKIT": "1",
    "MAVEN_CONFIG": "/home/vscode/.m2",
    "TESTCONTAINERS_DOCKER_SOCKET_OVERRIDE": "/var/run/docker.sock"
  },
  "remoteEnv": {
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },
  "mounts": [
    "source=maven-repo,target=/home/vscode/.m2/repository,type=volume",
    "source=npm-cache,target=/home/vscode/.npm,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "openai.chatgpt",
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "vmware.vscode-spring-boot"
      ],
      "settings": {
        "java.configuration.updateBuildConfiguration": "automatic",
        "maven.executable.path": "/usr/bin/mvn",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "postCreateCommand": "java -version && mvn -version && docker version && node -v && npm -v && codex --version || true",
  "postStartCommand": "docker ps >/dev/null && echo 'Docker daemon is reachable from the dev container.' || echo 'Docker daemon is not reachable from the dev container.'",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Spring Boot",
      "onAutoForward": "notify"
    }
  }
}
